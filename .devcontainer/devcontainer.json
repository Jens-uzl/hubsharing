{
   "name": "FHIR IG Dev",
   "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
   "features": {
     "ghcr.io/devcontainers/features/java:1": {
       "version": "21",
       "installGradle": false,
       "installMaven": false
     },
     "ghcr.io/devcontainers/features/ruby:1": {}
   },
   "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libxtst6 libxi6 libxrender1 && gem install jekyll && npm install -g fsh-sushi && sushi --version",
   "customizations": {
     "vscode": {
       "extensions": [
         "fhir-shorthand.vscode-fsh"
       ]
     }
   }
 }